# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ALLOWED_ORIGINS=*

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=sentrix
DB_PASSWORD=sentrix
DB_NAME=sentrix
DB_SSLMODE=disable

# Auth
JWT_SECRET=your-secret-key-here
JWT_EXPIRY_HOURS=24

# Logging
LOG_LEVEL=info
LOG_FORMAT=text

# LLM Providers
# Set API keys to enable system-level providers (available to all users).
# Users can also add their own provider configs via the UI.

# OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=sk-...

# Anthropic (https://console.anthropic.com/settings/keys)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (https://aistudio.google.com/app/apikey)
# GEMINI_API_KEY=AIza...

# DeepSeek (https://platform.deepseek.com/api_keys)
# DEEPSEEK_API_KEY=sk-...

# OpenRouter - unified access to 100+ models (https://openrouter.ai/keys)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Ollama - local models (no API key needed, just set the URL)
# OLLAMA_URL=http://localhost:11434

# Custom OpenAI-compatible endpoint (vLLM, LM Studio, LocalAI, etc.)
# CUSTOM_LLM_URL=http://localhost:8000/v1
# CUSTOM_LLM_MODEL=default
# CUSTOM_LLM_API_KEY=

# Which provider to use by default when no specific provider is requested
# Options: openai, anthropic, gemini, deepseek, openrouter, ollama, custom
# DEFAULT_LLM_PROVIDER=openai

# Search & Web Intelligence (Phase 7)
# SEARCH_DEFAULT_MAX_RESULTS=5
# SEARCH_TIMEOUT_SECONDS=30
# SEARCH_PROVIDER_PRIORITY=duckduckgo,tavily,searxng,google,perplexity,traversaal,sploitus

# DuckDuckGo
# DUCKDUCKGO_ENABLED=true

# Google Custom Search
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_CX=

# Tavily
# TAVILY_API_KEY=

# Traversaal
# TRAVERSAAL_API_KEY=

# Perplexity
# PERPLEXITY_API_KEY=
# PERPLEXITY_MODEL=sonar

# Searxng
# SEARXNG_URL=http://localhost:8081
# SEARXNG_LANGUAGE=en
# SEARXNG_CATEGORIES=general
# SEARXNG_SAFE_SEARCH=1

# Sploitus
# SPLOITUS_ENABLED=true

# Browser fetch tool
# BROWSER_USER_AGENT=Sentrix/0.7

# Scraper (rendered page retrieval + screenshots)
# When configured, the browser tool uses a scraper backend for JavaScript-rendered
# content and full-page screenshots instead of plain HTTP fetch.
# Setting either URL enables scraper mode and activates the Screenshots tab in the UI.
# SCRAPER_PUBLIC_URL=http://user:pass@scraper:3000/
# SCRAPER_PRIVATE_URL=http://user:pass@scraper:3000/

# Embedded scraper container settings (deployment-only, not loaded by backend)
# LOCAL_SCRAPER_USERNAME=sentrix
# LOCAL_SCRAPER_PASSWORD=sentrix
# LOCAL_SCRAPER_MAX_CONCURRENT_SESSIONS=5

# Security Tool Timeouts
# Default sqlmap timeout in seconds (default: 300 = 5 minutes).
# Lower values (e.g. 60-120) give faster probes at the cost of depth.
# The LLM can also override per-invocation via the sqlmap tool's timeout parameter.
# SQLMAP_DEFAULT_TIMEOUT_SECONDS=300

# Docker Sandbox (Phase 5)
# DOCKER_ENABLED=false
# DOCKER_SOCKET=/var/run/docker.sock
# DOCKER_DEFAULT_IMAGE=sentrix-tools:latest
# DOCKER_NETWORK=sentrix-sandbox
# DOCKER_DATA_DIR=./data/sandbox
# DOCKER_CPU_LIMIT=1.0
# DOCKER_MEMORY_LIMIT_MB=512
# DOCKER_CONTAINER_TIMEOUT=1800
# DOCKER_INSIDE=false

# Embedding / Memory (Phase 8)
# EMBEDDING_PROVIDER=none
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# EMBEDDING_DIMENSIONS=1536

# Observability (Phase 10)
# OBSERVABILITY_ENABLED=false
# OTEL_SERVICE_NAME=sentrix
# OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
# OTEL_TRACE_SAMPLE_RATE=1.0
# LANGFUSE_ENABLED=false
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
